# Application
APP_ENV=dev

# Database (prod mode)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cloud_core_kb

# Embedding — Zhipu AI Embedding-3 (prod mode)
EMBEDDING_API_KEY=your-zhipuai-api-key-here
EMBEDDING_MODEL=embedding-3
EMBEDDING_BASE_URL=https://open.bigmodel.cn/api/paas/v4
EMBEDDING_DIMENSIONS=2048

# LLM Service (for mining pipeline: question generation, enrichment, discourse analysis)
LLM_SERVICE_PROVIDER_BASE_URL=https://api.deepseek.com
LLM_SERVICE_PROVIDER_API_KEY=sk-your-api-key-here
LLM_SERVICE_PROVIDER_MODEL=deepseek-chat
LLM_SERVICE_PROVIDER_BYPASS_PROXY=false

# Mining LLM Client (set true when system proxy interferes with localhost calls)
MINING_LLM_BYPASS_PROXY=false
