# Application
APP_ENV=dev

# PostgreSQL — Mining & Serving 共用（自动建库建表）
PG_HOST=localhost
PG_PORT=5432
PG_DBNAME=coremasterkb
PG_USER=your_pg_user
PG_PASSWORD=your_pg_password
PG_SSLMODE=disable
PG_GSSENCMODE=disable
PG_POOL_MIN=2
PG_POOL_MAX=10

# Database (legacy)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cloud_core_kb

# Embedding — Zhipu AI Embedding-3 (prod mode)
EMBEDDING_API_KEY=your-zhipuai-api-key-here
EMBEDDING_MODEL=embedding-3
EMBEDDING_BASE_URL=https://open.bigmodel.cn/api/paas/v4
EMBEDDING_DIMENSIONS=2048

# LLM Service (for mining pipeline: question generation, enrichment, discourse analysis)
LLM_SERVICE_PROVIDER_BASE_URL=https://api.deepseek.com
LLM_SERVICE_PROVIDER_API_KEY=sk-your-api-key-here
LLM_SERVICE_PROVIDER_MODEL=deepseek-chat
LLM_SERVICE_PROVIDER_BYPASS_PROXY=false

# LLM Service model endpoints (for shared embedding / rerank capabilities)
# In the current project setup, embedding and rerank use the same BigModel key.
LLM_SERVICE_EMBEDDING_BASE_URL=https://open.bigmodel.cn/api/paas/v4
LLM_SERVICE_EMBEDDING_API_KEY=your-zhipuai-api-key-here
LLM_SERVICE_EMBEDDING_MODEL=embedding-3
LLM_SERVICE_EMBEDDING_DIMENSIONS=2048
LLM_SERVICE_RERANK_BASE_URL=https://open.bigmodel.cn/api/paas/v4
LLM_SERVICE_RERANK_API_KEY=your-zhipuai-api-key-here
LLM_SERVICE_RERANK_MODEL=rerank

# Serving direct fallback (only used when llm_service shared model endpoints are unavailable)
RERANK_API_KEY=your-zhipuai-api-key-here
RERANK_BASE_URL=https://open.bigmodel.cn/api/paas/v4
RERANK_MODEL=rerank

# Mining LLM Client (set true when system proxy interferes with localhost calls)
MINING_LLM_BYPASS_PROXY=false
